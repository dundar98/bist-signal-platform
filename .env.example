# =============================================================
#  BIST Signal Platform - VDS ENV DOSYASI
#  
#  KULLANIM:
#    cp .env.example .env
#    nano .env   (aşağıdaki DEĞİŞTİR yazan yerleri doldur)
# =============================================================

# Uygulama adı (değiştirmene gerek yok)
BIST_APP_NAME="BIST Signal Platform"
BIST_ENVIRONMENT=production

# ┌──────────────────────────────────────────────────────────┐
# │ VERİTABANI BAĞLANTISI                                     │
# │                                                          │
# │ ŞİFRE: Kendin güçlü bir şifre belirle (en az 12 karakter) │
# │ Aynı şifreyi 3 yere de yaz:                               │
# │   - POSTGRES_PASSWORD                                     │
# │   - BIST_DATABASE_URL                                     │
# │   - BIST_CONTAINER_DATABASE_URL                           │
# └──────────────────────────────────────────────────────────┘
POSTGRES_DB=bist
POSTGRES_USER=bist
POSTGRES_PASSWORD=BU_SIFREYI_DEGISTIR

# Docker içinde backend → postgres bağlantısı (postgres servis adıyla)
BIST_CONTAINER_DATABASE_URL=postgresql+psycopg://bist:BU_SIFREYI_DEGISTIR@postgres:5432/bist
# Lokal bağlantı (opsiyonel, sadece VDS dışından test için)
BIST_DATABASE_URL=postgresql+psycopg://bist:BU_SIFREYI_DEGISTIR@localhost:5432/bist

# ┌──────────────────────────────────────────────────────────┐
# │ GÜVENLİK ANAHTARI (JWT Secret Key)                        │
# │                                                          │
# │ Terminalde şu komutla rastgele anahtar üret:              │
# │   python3 -c "import secrets; print(secrets.token_urlsafe(48))" │
# │ Çıkan 64 karakterlik değeri aşağıya yapıştır.              │
# └──────────────────────────────────────────────────────────┘
BIST_SECRET_KEY=BU_64_KARAKTERLIK_RASTGELE_DEGERI_BURAYA_YAPISTIR

# Token geçerlilik süresi (dakika)
BIST_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ┌──────────────────────────────────────────────────────────┐
# │ CORS - Hangi adreslerden erişilebilir?                    │
# │ Domain YOKSA: VDS IP adresini yaz.                        │
# │ Domain VARSA:  https://domainin.com şeklinde yaz.         │
# │ Birden fazla adres için virgülle ayır.                    │
# └──────────────────────────────────────────────────────────┘
BIST_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80

# ┌──────────────────────────────────────────────────────────┐
# │ EMAIL BİLDİRİMLERİ (Opsiyonel)                            │
# │ Şimdilik boş bırakabilirsin, çalışmayı engellemez.        │
# │ Gmail için "App Password" oluşturman gerekir:             │
# │   https://myaccount.google.com/apppasswords               │
# └──────────────────────────────────────────────────────────┘
BIST_SMTP_SERVER=smtp.gmail.com
BIST_SMTP_PORT=587
BIST_EMAIL_SENDER=
BIST_EMAIL_PASSWORD=
BIST_EMAIL_RECIPIENTS=

# ┌──────────────────────────────────────────────────────────┐
# │ DİĞER AYARLAR (değiştirmene gerek yok)                    │
# └──────────────────────────────────────────────────────────┘
BIST_ALERT_WEBHOOK_URL=
BIST_BACKUP_DIR=backups
