BIST_APP_NAME="BIST Signal Platform"
BIST_ENVIRONMENT=local
BIST_DATABASE_URL=postgresql+psycopg://bist:bist@localhost:5432/bist
BIST_CONTAINER_DATABASE_URL=postgresql+psycopg://bist:bist@postgres:5432/bist
BIST_SECRET_KEY=change-me-before-production
BIST_ACCESS_TOKEN_EXPIRE_MINUTES=60
BIST_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
POSTGRES_DB=bist
POSTGRES_USER=bist
POSTGRES_PASSWORD=bist
APP_DOMAIN=localhost
ACME_EMAIL=admin@example.com
BIST_ALERT_WEBHOOK_URL=
BIST_BACKUP_DIR=backups

# Email notification settings (SMTP)
BIST_SMTP_SERVER=smtp.gmail.com
BIST_SMTP_PORT=587
BIST_EMAIL_SENDER=
BIST_EMAIL_PASSWORD=
BIST_EMAIL_RECIPIENTS=
