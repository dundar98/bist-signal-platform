# ┌──────────────────────────────────────────────────┐
# │  BIST Signal Platform — Production .env Sablonu  │
# │  BU DOSYAYI .env OLARAK KOPYALAYIP DEGISTIRIN    │
# └──────────────────────────────────────────────────┘

# Uygulama adı ve ortam
BIST_APP_NAME="BIST Signal Platform"
BIST_ENVIRONMENT=production

# Veritabanı bağlantıları
# DOCKER ICIN: postgresql+psycopg://KULLANICI:SIFRE@postgres:5432/bist
# LOKAL ICIN:  postgresql+psycopg://KULLANICI:SIFRE@localhost:5432/bist
BIST_DATABASE_URL=postgresql+psycopg://bist:BURAYA_GUVENLI_SIFRE_YAZ@postgres:5432/bist
BIST_CONTAINER_DATABASE_URL=postgresql+psycopg://bist:BURAYA_GUVENLI_SIFRE_YAZ@postgres:5432/bist

# GUVENLIK: Asagidaki komutla rastgele bir secret key uretin:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
BIST_SECRET_KEY=BURAYA_64_KARAKTERLIK_RASTGELE_ANAHTAR_YAZ

# Token suresi (dakika)
BIST_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Hangi domain'lerden erisilebilir? (virgulle ayir)
BIST_CORS_ORIGINS=https://SENIN_DOMAININ.com,https://www.SENIN_DOMAININ.com

# PostgreSQL kullanicisi
POSTGRES_DB=bist
POSTGRES_USER=bist
POSTGRES_PASSWORD=BURAYA_GUVENLI_SIFRE_YAZ

# Domain ve SSL (Let's Encrypt icin)
APP_DOMAIN=SENIN_DOMAININ.com
ACME_EMAIL=SENIN_GERCEK_EMAILIN@gmail.com

# Opsiyonel: Alert webhook (Discord/Slack/Telegram)
BIST_ALERT_WEBHOOK_URL=

# Yedekleme dizini
BIST_BACKUP_DIR=backups

# E-posta bildirim ayarlari (SMTP - Gmail App Password gerekli)
BIST_SMTP_SERVER=smtp.gmail.com
BIST_SMTP_PORT=587
BIST_EMAIL_SENDER=SENIN_GMAILIN@gmail.com
BIST_EMAIL_PASSWORD=SENIN_16_KARAKTERLIK_APP_PASSWORD
BIST_EMAIL_RECIPIENTS=kullanici1@email.com,kullanici2@email.com
